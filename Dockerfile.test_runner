FROM oven/bun:1.3.10

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    ripgrep \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

COPY . .

# Install dependencies
RUN bun install

ENTRYPOINT ["bun", "run", "./packages/opencode/bin/freecode"]
