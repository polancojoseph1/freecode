FROM oven/bun:1.3.10

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    ripgrep \
    python3 \
    python3-pip \
    && python3 -m pip install setuptools --break-system-packages \
    && rm -rf /var/lib/apt/lists/*

# Configure git identity
RUN git config --global user.email "bot@test.ai" \
    && git config --global user.name "testbot"

# Copy full project (monorepo workspaces need all package.json files)
COPY . .

# Install dependencies
RUN bun install

# Environment
ENV CI=true
ENV OPENAI_BASE_URL=http://localhost:9999/v1

# Integration test support: pass OPENROUTER_API_KEY at build time to enable live agent tests
ARG OPENROUTER_API_KEY
ENV OPENROUTER_API_KEY=$OPENROUTER_API_KEY
# If OPENROUTER_API_KEY is provided, enable integration mode (preserves provider keys in test preload)
ARG FREECODE_INTEGRATION
ENV FREECODE_INTEGRATION=$FREECODE_INTEGRATION

# Run tests (120s timeout to support integration tests hitting live AI providers)
CMD ["bun", "--cwd", "packages/opencode", "test", "--timeout", "120000"]
