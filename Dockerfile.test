FROM oven/bun:1.3.10

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    ripgrep \
    python3 \
    python3-pip \
    && python3 -m pip install setuptools --break-system-packages \
    && rm -rf /var/lib/apt/lists/*

# Configure git identity
RUN git config --global user.email "bot@test.ai" \
    && git config --global user.name "testbot"

# Copy full project first (monorepo workspaces need all package.json files)
COPY . .

# Install dependencies
RUN bun install

# Environment
ENV CI=true
ENV OPENAI_BASE_URL=http://localhost:9999/v1

# Integration test support: pass at runtime via docker run -e
# OPENROUTER_API_KEY — enables live AI provider tests
# FREECODE_INTEGRATION=1 — preserves provider keys in test preload

# Run tests (120s timeout for integration tests)
# Note: runs as root — 1 file-permission test will false-positive (root can write to read-only)
CMD ["bun", "--cwd", "packages/opencode", "test", "--timeout", "120000"]
